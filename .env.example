# ---- Strongly recommended ----
# Shared secret. If set, every /api/* call requires header `x-dashboard-token`.
# The UI prompts once and stores it in sessionStorage. Without this, anyone with
# the URL can read your position size and equity. Set it.
DASHBOARD_TOKEN=

# ---- Optional: Telegram alerts (stop hits, stop-near, entry signals) ----
# Create a bot with @BotFather; get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Optional: future real-time upgrade slot ----
# v1 uses keyless sources (Yahoo delayed ~15min for MSTR, live Binance/Coinbase
# for BTC, Stooq EOD fallback). Drop a key here later and swap the adapter in
# netlify/shared/sources.mjs for true real-time equity quotes.
# POLYGON_API_KEY=
# FINNHUB_API_KEY=
