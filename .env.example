# ---- Required ----
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Your wallet holding the Aave V3 (Arbitrum) WBTC position. Read-only public data.
AAVE_WALLET_ADDRESS=0xYourWalletAddress

# For the "morning take" narrative + token cost tracking.
ANTHROPIC_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with contact info (their fair-use policy).
EDGAR_USER_AGENT="MacroCommandCenter your-email@example.com"

# ---- Recommended ----
# Shared secret. If set, every /api/* call requires header `x-dashboard-token`.
# The UI prompts once and stores it in sessionStorage. Without this, anyone with
# the URL can read your position data. Set it.
DASHBOARD_TOKEN=

# ---- Optional ----
# CoinGecko demo key raises rate limits (works keyless too): x-cg-demo-api-key
COINGECKO_API_KEY=
# Override the public Arbitrum RPC if it rate-limits you (e.g. an Alchemy/Infura URL)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# Narrative model + monthly budget default (USD)
NARRATIVE_MODEL=claude-sonnet-4-6
